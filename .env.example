# ================================================================
# PsikoPanel — Environment Variables
# Bu dosyayı .env.local olarak kopyalayın ve değerleri doldurun
# Vercel: Settings > Environment Variables bölümünden ekleyin
# ================================================================

# ── Supabase (Zorunlu) ──────────────────────────────────────────
# Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Uygulama URL'i (Zorunlu) ────────────────────────────────────
# Local: http://localhost:3000
# Production: https://sizin-domaininiz.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Resend — E-posta Bildirimleri (Opsiyonel) ───────────────────
# https://resend.com/api-keys
# Yoksa e-posta gönderimi sessizce atlanır
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=bildirim@sizin-domaininiz.com

# ── Web Push — Tarayıcı Bildirimleri (Opsiyonel) ────────────────
# Üretmek için: npx web-push generate-vapid-keys
# Yoksa push bildirimleri devre dışı kalır
NEXT_PUBLIC_VAPID_PUBLIC_KEY=Bxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_SUBJECT=mailto:admin@sizin-domaininiz.com

# ── Upstash Redis — Rate Limiting (Opsiyonel) ───────────────────
# https://console.upstash.com
# Yoksa in-memory fallback kullanılır (tek instance için yeterli)
UPSTASH_REDIS_REST_URL=https://xxxxxxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Cron Job Güvenliği (Production için Zorunlu) ────────────────
# Vercel Cron'un /api/cron/reminders'ı çağırmasına izin verir
# Üretmek için: openssl rand -hex 32
CRON_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
